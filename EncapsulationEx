package Encapsulation;
class Student
{
	private int id;
	private String name;
	public int getId() 
	{
		return id;
	}
	public void setId(int id) 
	{
		this.id = id;
	}
	public String getName() 
	{
		return name;
	}
	public void setName(String name)
	{
		this.name = name;
	}
}
public class Exampl 
{

	public static void main(String[] args)
	{
      Student S = new Student();
      S.setId(101);
      S.setName("Ravi");
      
      System.out.println(S.getId()+ " "+S.getName());
	}

}
